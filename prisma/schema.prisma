generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  name      String?
  avatarUrl String?
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]

  @@map("profiles")
}

model Member {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  birthday      DateTime?
  anniversary   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  donations     Donation[]
  notifications Notification[]

  @@map("members")
}

model Donation {
  id               String    @id @default(cuid())
  amount           Decimal   @db.Decimal(10, 2)
  status           String    @default("pending")
  reference        String    @unique
  memberId         String?
  gateway          String    @default("paystack")
  gatewayReference String?
  paymentMethod    String?
  channel          String?
  metadata         Json?
  donorName        String?
  donorEmail       String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  member           Member?   @relation(fields: [memberId], references: [id])

  @@index([reference])
  @@index([status])
  @@map("donations")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @default("")
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      Profile?  @relation(fields: [authorId], references: [id])

  @@index([published, publishedAt])
  @@map("posts")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  imageUrl    String?
  rsvpEnabled Boolean  @default(false)
  rsvpLimit   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rsvps       Rsvp[]

  @@index([date])
  @@map("events")
}

model Rsvp {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String
  guests    Int      @default(1)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@map("rsvps")
}

model Notification {
  id        String    @id @default(cuid())
  message   String
  memberId  String
  type      String    @default("general")
  channel   String    @default("email")
  status    String    @default("pending")
  sentAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, type, createdAt], name: "unique_member_type_date")
  @@map("notifications")
}

model Sermon {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  sermonDate  DateTime
  speaker     String
  series      String?
  audioUrl    String?
  videoUrl    String?
  duration    Int?
  imageUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sermonDate])
  @@index([published, publishedAt])
  @@map("sermons")
}
