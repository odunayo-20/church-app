# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Church App

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Supabase - Get these from Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/church_app"

# Resend - Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron Secret - Used to protect the cron endpoint
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here
